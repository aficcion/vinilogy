# Vinylbe v2 — configuración de entorno
# Única fuente de datos: vinology_core. La app SOLO LEE el catálogo; la capa de
# usuario SÍ escribe en app_users/user_sessions (es su función; NUNCA hace DDL).
VINYLBE_DB_DSN=postgresql://localhost/vinology_core
PORT=7788

# Vida de la sesión de usuario (días). Cookie httponly `vb_session`. (def. 90)
# VINYLBE_SESSION_TTL_DAYS=90

# LOGIN-DEV (SOLO desarrollo/pruebas): con =1 se monta POST /dev/login/{user_id},
# que abre sesión para un usuario EXISTENTE sin OAuth. Es el gancho de prueba de la
# capa personal antes del OAuth real (M3b). NUNCA activar en producción.
# VINYLBE_DEV_LOGIN=1

# ---------------------------------------------------------------------------
# OAuth — cada proveedor degrada suave si falta (login "no configurado", no 500)
# ---------------------------------------------------------------------------
# Base pública para construir los redirect_uri de OAuth (debe casar EXACTO con lo
# registrado en cada proveedor). En local: http://localhost:7788
# VINYLBE_BASE_URL=http://localhost:7788

# Google — IDENTIDAD (OAuth2/OIDC). Crea un "OAuth 2.0 Client ID" (tipo Web) en
# Google Cloud Console y añade el redirect URI: <VINYLBE_BASE_URL>/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Discogs — colección/gap (OAuth 1.0a). Redirect: <BASE_URL>/auth/discogs/callback
# DISCOGS_KEY=
# DISCOGS_SECRET=

# Last.fm — escucha/reco. Callback: <BASE_URL>/auth/lastfm/callback
# LASTFM_API_KEY=
# LASTFM_API_SECRET=
